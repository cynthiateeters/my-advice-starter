# Dependencies — installed by npm, never committed (too large, always reproducible)
node_modules

# Build output — generated by `npm run build`, never committed
# See docs/tutorials/project-structure.md for why
dist

# macOS metadata file — created automatically, not part of the project
.DS_Store

# Environment variables — may contain secrets (API keys, tokens)
.env

# AI tool working directories — session history, not project code
.specstory/
.claude/

# Local config overrides — personal settings that should not affect other contributors
*.local

# Generated snapshots — can always be regenerated
repomix-output.*

# Instructor reports — not part of the student deliverable
reports/
